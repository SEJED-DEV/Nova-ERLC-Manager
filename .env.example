# ── Bot Configuration ─────────────────────────────────────────────────────────
TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here
BOT_NAME=Nova ERLC Manager
BOT_STATUS_TEXT=Watching ER:LC Private Server

# ── Role Configuration ────────────────────────────────────────────────────────
# STAFF_ROLE_ID: The ID of the role allowed to use staff commands (/infraction, etc.)
STAFF_ROLE_ID=your_staff_role_id_here

# NOTIFICATIONS_ROLE_ID: Role(s) to ping for sessions. 
# You can use a single ID, or a comma-separated list of IDs.
# Supports special values: "everyone" and "here".
# The FIRST role in the list will be used for the opt-in/out button.
NOTIFICATIONS_ROLE_ID=your_role_id_here,everyone

# ── Channel Configuration ─────────────────────────────────────────────────────
LOGS_CHANNEL_ID=your_logs_channel_id_here
SESSION_CHANNEL_ID=your_session_channel_id_here
ANNOUNCEMENTS_CHANNEL_ID=your_announcements_channel_id_here

# ── ERLC API Configuration ────────────────────────────────────────────────────
# SERVER_KEY: The "Server Key" from your ERLC Private Server settings panel.
ERLC_SERVER_KEY=your_erlc_server_key_here

# ── Session Details ──────────────────────────────────────────────────────────
SERVER_NAME=Your Server Name
SERVER_OWNER=OwnerName
JOIN_CODE=ABCDE
QUICK_JOIN_URL=https://policeroleplay.community/join/ABCDE

# ── Image Branding ──────────────────────────────────────────────────────────
HEADER_IMAGE=https://example.com/header.png
FOOTER_IMAGE=https://example.com/footer.png

# ── Custom Messages ──────────────────────────────────────────────────────────
MSG_SESSION_BOOST=**The session is currently slow!**\nJoin up!
MSG_SESSION_FULL=**The server is currently full!**\nStay in queue!
MSG_SESSION_SHUTDOWN=**The session has officially concluded.**\nThanks for joining!

# ── Custom Emojis ────────────────────────────────────────────────────────────
EMOJI_CHECK=✅
EMOJI_USERS=👥
EMOJI_TADA=🎉
EMOJI_GIFT=🎁
